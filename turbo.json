{
	"$schema": "https://turborepo.com/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"env": [
				"VITE_CONVEX_URL",
				"VITE_CONVEX_SITE_URL",
				"VITE_SITE_URL",
				"NODE_ENV"
			],
			"outputs": ["dist/**", ".output/**", "!.output/cache/**"]
		},
		"dev": {
			"persistent": true,
			"cache": false
		},
		"lint": {},
		"typecheck": {
			"inputs": [
				"$TURBO_DEFAULT$",
				"!**/*.md",
				"!**/claudedocs/**",
				"!**/.vscode/**"
			],
			"outputs": ["**/*.tsbuildinfo"]
		},
		"codegen": {
			"inputs": [
				"convex/functions/**/*.ts",
				"!convex/functions/_generated/**",
				"!convex/functions/generated/**"
			],
			"outputs": [
				"convex/functions/_generated/**",
				"convex/functions/generated/**",
				"convex/shared/api.ts"
			]
		}
	}
}
